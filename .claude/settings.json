{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "Edit(/brain/**)",
      "Write(/brain/**)",
      "Bash(git *)"
    ],
    "deny": [
      "WebFetch",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod *)",
      "Bash(ssh *)",
      "Bash(git rm *)",
      "Bash(git checkout *)",
      "Bash(git restore *)",
      "Bash(git push *)",
      "Bash(git config *)",
      "Bash(git -c *)",
      "Edit(/OVERSEER.md)",
      "Write(/OVERSEER.md)",
      "Edit(/CLAUDE.md)",
      "Write(/CLAUDE.md)",
      "Edit(/.claude/**)",
      "Write(/.claude/**)"
    ]
  }
}
